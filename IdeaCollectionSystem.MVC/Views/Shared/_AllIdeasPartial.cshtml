@using IdeaCollectionSystem.Service.Models.DTOs
@model IEnumerable<IdeaInfoDto>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center">No ideas submitted yet.</div>
}
else
{
    <div class="row g-3">
        @foreach (var idea in Model)
        {
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h5 class="card-title mb-1">
                                    @idea.Title
                                    @if (idea.IsAnonymous)
                                    {
                                        <span class="badge bg-secondary ms-1"><i class="fas fa-user-secret"></i> Anonymous</span>
                                    }
                                </h5>
                                <div class="text-muted small mb-2">
                                    <i class="fas fa-user me-1"></i>@idea.AuthorName
                                    <span class="mx-2">|</span>
                                    <i class="fas fa-tag me-1"></i>@idea.CategoryName
                                    @if (!string.IsNullOrEmpty(idea.DepartmentName))
                                    {
                                        <span class="mx-2">|</span>
                                        <i class="fas fa-building me-1"></i>

                                        @idea.DepartmentName
                                    }
                                    <span class="mx-2">|</span>
                                    <i class="fas fa-clock me-1"></i>@idea.CreatedDate.ToString("dd/MM/yyyy")
                                </div>
                            </div>
                            <!-- Vote Buttons -->
                            <div class="d-flex align-items-center gap-2 ms-3">
                                <button class="btn btn-sm btn-outline-success vote-btn"
                                        data-idea-id="@idea.Id" data-is-thumbsup="true"
                                        title="Thumbs Up">
                                    <i class="fas fa-thumbs-up"></i>
                                    <span class="vote-up-count">@idea.ThumbsUpCount</span>
                                </button>
                                <button class="btn btn-sm btn-outline-danger vote-btn"
                                        data-idea-id="@idea.Id" data-is-thumbsup="false"
                                        title="Thumbs Down">
                                    <i class="fas fa-thumbs-down"></i>
                                    <span class="vote-down-count">@idea.ThumbsDownCount</span>
                                </button>
                                <span class="badge bg-light text-dark border">
                                    <i class="fas fa-comment text-muted me-1"></i>@idea.CommentCount
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}