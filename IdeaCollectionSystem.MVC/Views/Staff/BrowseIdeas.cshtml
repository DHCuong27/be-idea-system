@using IdeaCollectionSystem.Service.Models.DTOs
@model IEnumerable<IdeaInfoDto>
@{
    ViewData["Title"] = "Browse Ideas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-lightbulb text-warning me-2"></i>Browse Ideas</h2>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
    </div>
    <partial name="_AllIdeasPartial" model="Model" />
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.vote-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var ideaId = this.dataset.ideaId;
                var isThumbsUp = this.dataset.isThumbsup === 'true';
                var card = this.closest('.card-body');

                fetch('/Staff/Vote', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' },
                    body: 'ideaId=' + ideaId + '&isThumbsUp=' + isThumbsUp
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        // Reload to update counts
                        location.reload();
                    }
                });
            });
        });
    </script>
}