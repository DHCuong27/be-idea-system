@using IdeaCollectionSystem.Service.Models.DTOs
@model IEnumerable<DepartmentStatDto>
@{
    ViewData["Title"] = "Statistics";
    var isAdmin = User.IsInRole("Administrator");
    var ctrl = isAdmin ? "Admin" : "QAManager";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-chart-bar text-danger me-2"></i>Department Statistics</h2>
        <a asp-controller="@ctrl" asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>Back
        </a>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var dept in Model)
        {
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-primary text-white">
                        <strong>@dept.DepartmentName</strong>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Ideas Submitted</span>
                            <span class="badge bg-primary">@dept.IdeaCount</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Contributors</span>
                            <span class="badge bg-success">@dept.ContributorCount</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Share</span>
                            <span class="badge bg-info">@dept.Percentage%</span>
                        </div>
                        <div class="progress mt-3" style="height:8px">
                            <div class="progress-bar bg-primary" style="width: @dept.Percentage%"></div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Table Summary -->
    <div class="card shadow-sm">
        <div class="card-header"><strong>Summary Table</strong></div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Department</th>
                        <th class="text-center">Ideas</th>
                        <th class="text-center">Contributors</th>
                        <th class="text-center">Share</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model.OrderByDescending(d => d.IdeaCount))
                    {
                        <tr>
                            <td>@dept.DepartmentName</td>
                            <td class="text-center">@dept.IdeaCount</td>
                            <td class="text-center">@dept.ContributorCount</td>
                            <td class="text-center">
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar" style="width:@dept.Percentage%"></div>
                                </div>
                                <small>@dept.Percentage%</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>