@{
    ViewData["Title"] = "QA Coordinator Dashboard";
}

<div class="container mt-4">
    <h2><i class="fas fa-building text-info me-2"></i>QA Coordinator Dashboard</h2>
    <p class="text-muted">Department-level management and oversight.</p>
    <hr />

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="fas fa-lightbulb fa-3x text-primary mb-3"></i>
                    <h6>Department Ideas</h6>
                    <p class="small text-muted">View all ideas from your department.</p>
                    <a asp-action="DepartmentIdeas" class="btn btn-outline-primary w-100">View Ideas</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="fas fa-chart-pie fa-3x text-success mb-3"></i>
                    <h6>Department Statistics</h6>
                    <p class="small text-muted">View statistics for all departments.</p>
                    <a asp-action="DepartmentStatistics" class="btn btn-outline-success w-100">View Stats</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center py-4">
                    <i class="fas fa-plus-circle fa-3x text-warning mb-3"></i>
                    <h6>Submit Idea</h6>
                    <p class="small text-muted">Submit a new idea as a coordinator.</p>
                    <a asp-controller="Staff" asp-action="Terms" class="btn btn-outline-warning w-100">Submit</a>
                </div>
            </div>
        </div>
    </div>
</div>