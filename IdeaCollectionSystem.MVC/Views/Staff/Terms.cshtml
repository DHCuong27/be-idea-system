@{
    ViewData["Title"] = "Terms and Conditions";
}

<div class="container mt-5">
    <div class="card">
        <div class="card-header bg-warning">
            <h4>Terms and Conditions</h4>
        </div>
        <div class="card-body">
            <p>Before submitting your idea, please read and agree to our terms:</p>
            <ul>
                <li>Ideas and comments can be posted anonymously, but your details are stored for security.</li>
                <li>Inappropriate content will be investigated.</li>
                <li>Attachments must be relevant to the idea[cite: 18].</li>
            </ul>
            <form asp-action="AcceptTerms" method="post">
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" name="agree" value="true" required>
                    <label class="form-check-label">I agree to the Terms and Conditions</label>
                </div>
                <button type="submit" class="btn btn-primary">Continue</button>
            </form>
        </div>
    </div>
</div>